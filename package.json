{
  "name": "style-print-jung",
  "version": "1.0.0",
  "private": true,
  "description": "UI Facet Mixer - Extract and mix UI design facets from reference screenshots",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:api": "tsx watch apps/api/src/server.ts",
    "dev:web": "vite --config apps/web/vite.config.ts --host 0.0.0.0",
    "build": "npm run typecheck && npm run build:web",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "start": "tsx apps/api/src/server.ts",
    "typecheck": "tsc -p apps/api/tsconfig.json && tsc -p apps/web/tsconfig.json",
    "lint": "npm run typecheck"
  },
  "dependencies": {
    "@codesandbox/sandpack-react": "^2.20.0",
    "@fastify/multipart": "^10.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "chroma-js": "^3.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "lucide-react": "^0.563.0",
    "nanoid": "^5.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.4.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.24",
    "eslint": "^8.56.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.8.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.7"
  }
}
