# OpenAI API Configuration
# Used for screenshot design facet analysis and generated-code audit.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional. Defaults to OPENAI_MODEL when unset.
OPENAI_JUDGE_MODEL=gpt-4.1-mini

# v0 API Configuration
# Used only for React + Tailwind code generation.
# Get your API key from https://v0.dev/
V0_API_KEY=
V0_MODEL=v0-mini

# API server
API_PORT=4000
# Comma-separate multiple frontend origins for Vercel preview/production URLs.
WEB_ORIGIN=http://localhost:5173

# Frontend deployment
# Set this to the Railway backend URL in Vercel, for example:
# VITE_API_BASE_URL=https://style-print-jung-api.up.railway.app
VITE_API_BASE_URL=

# Deployment smoke checks
# SMOKE_API_BASE_URL=https://style-print-jung-api.up.railway.app
# SMOKE_WEB_BASE_URL=https://style-print-jung.vercel.app
